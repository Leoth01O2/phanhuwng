<section id="gallery" class="section">

    <h2>Gallery</h2>

    <div class="gallery-grid">

        <img src="/images/pic1.jpg" onclick="openImage(this)">
        <img src="/images/pic2.jpg" onclick="openImage(this)">
        <img src="/images/pic3.jpg" onclick="openImage(this)">
