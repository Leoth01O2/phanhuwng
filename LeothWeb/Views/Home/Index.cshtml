<!-- lightbox -->

<div id="imageViewer" onclick="closeImage()">

    <img id="viewerImg">

</div>
                        

<section id="guestbook" class="section">

    <h2>Guestbook</h2>

    <!-- Form gửi message -->
    <form method="post" action="/Guestbook/Add">

        <input name="name" placeholder="Your name" />

        <textarea name="message"
                  placeholder="Leave a message..."></textarea>

        <button type="submit">
            Send
        </button>

    </form>

    <!-- Danh sách message -->
    <div id="guestMessages">

        @foreach (var m in Model)
        {
            <div class="guest-item">

                <b>@m.Name</b>

                <p>@m.Message</p>

            </div>
        }

    </div>

</section>